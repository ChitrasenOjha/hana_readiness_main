<mvc:View
    controllerName="hanareadinessmain.controller.ATCResults"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page
        id="atcResultsPage"
        title="ATC Findings"
        enableScrolling="true"
        showNavButton="true"
        navButtonPress=".onNavBack"
        showHeader="false">

        <content>
<Panel id="_IDGenPanel5"
    headerText="ATC Findings"
    class="sapUiResponsiveMargin atcPanel">

    <headerToolbar>
        <OverflowToolbar id="_IDGenOverflowToolbar">

            <Title id="_IDGenTitle6"
                text="ATC Findings"
                level="H4"/>

            <ToolbarSpacer id="_IDGenToolbarSpacer"/>

            <SearchField id="_IDGenSearchField"
                width="20rem"
                placeholder="Search Findings"/>

            <Button id="_IDGenButton2"
                icon="sap-icon://filter"
                tooltip="Filter"/>

            <Button id="_IDGenButton3"
                icon="sap-icon://excel-attachment"
                tooltip="Export"/>

        </OverflowToolbar>
    </headerToolbar>

    <Table
        id="atcTable"
        growing="true"
        growingScrollToLoad="true"
        sticky="ColumnHeaders"
        items="{ATCModel>/ATCResults}">

        <columns>

            <Column id="_IDGenColumn" width="18rem">
                <Text id="_IDGenText10" text="Report Name"/>
            </Column>

            <Column id="_IDGenColumn1" width="8rem">
                <Text id="_IDGenText11" text="Line Number"/>
            </Column>

            <Column id="_IDGenColumn2" width="6rem">
                <Text id="_IDGenText12" text="Priority"/>
            </Column>

            <Column id="_IDGenColumn3" width="30rem">
                <Text id="_IDGenText13" text="ATC/CI Error Text"/>
            </Column>

            <Column id="_IDGenColumn4" hAlign="Center">
                <Text id="_IDGenText14" text="Action"/>
            </Column>

        </columns>

        <items>

            <ColumnListItem id="_IDGenColumnListItem" type="Navigation">

    <cells>

        <ObjectIdentifier id="_IDGenObjectIdentifier"
            title="{ATCModel>ObjName}"/>

        <ObjectNumber id="_IDGenObjectNumber"
            number="{ATCModel>LINE}"/>

        <ObjectStatus id="_IDGenObjectStatus"
            text="{ATCModel>Priority}"
            state="Error"/>

        <Text id="_IDGenText15"
            text="{ATCModel>Message}"
            wrapping="false"/>

        <Button id="_IDGenButton4"
            icon="sap-icon://action"
            type="Transparent"
            tooltip="Open"/>

    </cells>

</ColumnListItem>

        </items>

    </Table>

</Panel>
</content>

    </Page>

</mvc:View>